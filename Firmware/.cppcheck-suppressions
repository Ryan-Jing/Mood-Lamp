# cppcheck suppressions for the Mood Lamp firmware.
# One id per line. Used by CI and the pre-push hook via --suppressions-list.

# Arduino / ESP-IDF / library headers aren't on cppcheck's include path — that's
# expected, we only analyse our own sources.
missingIncludeSystem
missingInclude

# unusedFunction is cross-translation-unit and false-positives on HAL entry points
# that are only called from other .cpp files (or the Arduino framework).
unusedFunction

# Silence cppcheck's own "consider --check-level=exhaustive" nag and unmatched
# suppression noise so the report stays clean.
checkersReport
unmatchedSuppression

# FreeRTOS task functions must match TaskFunction_t = void(*)(void*). Their
# pvParameters can't be made const without breaking the callback's function-pointer
# type, so cppcheck's constParameterCallback suggestion doesn't apply here.
constParameterCallback
